{
  "name": "blog",
  "version": "1.0.0",
  "type": "module",
  "description": "Source code of my blog (https://nisanthchunduru.com)",
  "main": "backend/dist/google-cloud-functions/index.js",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "build:backend": "cd backend && tsc",
    "build:frontend": "esbuild backend/assets/js/application.ts --bundle --minify --outfile=backend/public/assets/application.js",
    "build:css": "tailwindcss -i backend/assets/css/application.css -o backend/public/assets/application.css --minify",
    "fingerprint-assets": "node scripts/fingerprint-assets.cjs",
    "build:google-cloud-functions": "npm run build:backend && npm run build:frontend && npm run build:css && npm run fingerprint-assets",
    "gcp-build": "npm run build:google-cloud-functions"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.995.0",
    "@aws-sdk/client-s3": "^3.995.0",
    "@aws-sdk/util-dynamodb": "^3.995.0",
    "@google-cloud/storage": "^7.21.0",
    "@hotwired/stimulus": "^3.2.2",
    "@hotwired/turbo": "^8.0.23",
    "@notionhq/client": "^2.2.15",
    "@vendia/serverless-express": "^4.12.6",
    "date-fns": "^3.0.6",
    "dotenv": "^16.4.5",
    "ejs": "^5.0.2",
    "express": "^4.18.2",
    "express-ejs-layouts": "^2.5.1",
    "file-system-cache": "^2.4.7",
    "ioredis": "^5.9.3",
    "js-yaml": "^4.1.0",
    "lodash": "^4.17.21",
    "pluralize": "^8.0.0",
    "slugify": "^1.6.6"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "@types/ejs": "^3.1.5",
    "@types/express": "^4.17.21",
    "@types/express-ejs-layouts": "^2.5.4",
    "@types/js-yaml": "^4.0.9",
    "@types/lodash": "^4.14.202",
    "@types/node": "^20.10.6",
    "@types/pluralize": "^0.0.33",
    "autoprefixer": "^10.5.0",
    "esbuild": "^0.28.0",
    "postcss": "^8.5.14",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.7.1",
    "typescript": "^5.3.3"
  }
}
