<div class="container mx-auto px-4 mt-4 md:mt-12 pb-24 md:pb-16" style="flex: 1">
  <div class="mx-auto max-w-none prose-h1:text-center">
    <div class="prose sm:prose-lg dark:prose-invert relative" style="overflow-wrap: break-word">
      <%- aboutHtml.replace('👋', '<span class="wave-emoji">👋</span>') %>
    </div>
  </div>
  <section class="mx-auto max-w-[720px] mt-14 md:mt-16">
    <h2 class="text-3xl font-light mt-0 mb-6 md:mb-8 text-violet-950 dark:text-violet-300">Latest Posts</h2>
    <div class="flex flex-col gap-6">
      <% recentPosts.forEach(post => { %>
        <article class="p-5 sm:p-6 rounded-2xl bg-white dark:bg-neutral-900/15 border border-neutral-200/70 dark:border-neutral-800/80 hover:border-brand/30 dark:hover:border-brand-light/35 transition-all duration-200 shadow-sm hover:shadow">
          <h3 class="text-2xl font-light mb-2">
            <a class="text-gray-900 dark:text-gray-100 hover:text-brand dark:hover:text-brand-light transition-colors" href="/posts/<%= post.slug %>"><%= post.title %></a>
          </h3>
          <% if (post.subheading) { %>
            <p class="text-base leading-relaxed text-gray-600 dark:text-gray-400 mb-4"><%= post.subheading %></p>
          <% } %>
          <div class="flex flex-wrap items-center gap-2 mt-4 pt-3 border-t border-neutral-100 dark:border-neutral-800/40 text-xs">
            <time class="text-neutral-400 dark:text-neutral-500" datetime="<%= post.publishedDate %>"><%= formatTime(post.publishedDate) %></time>
            <% if (post.tags && post.tags.length > 0) { %>
              <span class="text-neutral-300 dark:text-neutral-700">&bull;</span>
              <%- include('../partials/tags', { tags: post.tags }) %>
            <% } %>
          </div>
        </article>
      <% }) %>
    </div>
    <div class="mt-5">
      <a class="text-brand hover:underline" href="/posts">View all posts</a>
    </div>
  </section>
  <div class="mx-auto max-w-[720px] mt-14 md:mt-16">
    <div class="max-w-[600px]">
      <%- include('../partials/chirps_feed', { chirpGroups, feedTitle: 'Latest Chirps', titleClassName: 'text-3xl font-light mt-0 mb-6 md:mb-8 text-violet-950 dark:text-violet-300' }) %>
    </div>
    <div class="mt-5">
      <a class="text-brand hover:underline" href="/chirps">View all chirps</a>
    </div>
  </div>
</div>
