<div class="container mx-auto mt-8 px-4 max-w-none pb-24 md:pb-16" style="flex: 1" data-controller="highlight">
  <div class="article mt-6">
    <h1 class="text-center text-4xl font-heading font-normal mb-3 text-violet-950 dark:text-brand-light"><%= chirp.title %></h1>
    <div class="flex flex-wrap items-center justify-center gap-2 mb-12">
      <p class="text-gray-500 dark:text-gray-400"><%= formatTime(chirp.publishedDate) %></p>
      <% if (chirp.tags && chirp.tags.length > 0) { %>
        <span class="text-gray-400 dark:text-gray-500">&bull;</span>
        <div class="flex flex-wrap gap-2">
          <% chirp.tags.forEach(tag => { %>
            <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-violet-100 dark:bg-violet-900 text-violet-800 dark:text-violet-200"><%= tag %></span>
          <% }) %>
        </div>
      <% } %>
    </div>
    <div class="prose sm:prose-lg dark:prose-invert" style="text-align: justify; overflow-wrap: break-word">
      <%- chirp.html %>
    </div>
  </div>
</div>
