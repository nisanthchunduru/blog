<div class="container mx-auto px-4 mt-6 md:mt-16 pb-12 md:pb-16 max-w-3xl" style="flex: 1">
  <div class="flex flex-col gap-12 md:gap-16">
    <% yearGroups.forEach(([year, yearPosts])=> { %>
      <div class="grid grid-cols-1 md:grid-cols-[100px_1fr] gap-4 md:gap-8 items-start">

        <!-- Year Header -->
        <div class="text-2xl font-bold font-heading text-violet-600 dark:text-violet-400 text-left md:pt-6">
          <%= year %>
        </div>

        <!-- Year Posts List -->
        <div class="flex flex-col gap-6">
          <% yearPosts.forEach(post=> { %>
            <article>
              <a class="group block cursor-pointer p-5 sm:p-6 rounded-2xl bg-white dark:bg-neutral-900/15 border border-neutral-200/70 dark:border-neutral-800/80 hover:border-brand/30 dark:hover:border-brand-light/35 transition-all duration-200 shadow-sm hover:shadow focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand dark:focus-visible:ring-brand-light"
                href="/posts/<%= post.slug %>">
                <h2 class="text-xl sm:text-2xl font-semibold leading-snug text-neutral-900 dark:text-neutral-50 group-hover:text-brand dark:group-hover:text-brand-light transition-colors">
                  <%= post.title %>
                </h2>

                <% if (post.subheading) { %>
                  <p class="text-sm text-neutral-600 dark:text-neutral-400 leading-relaxed font-light mt-2">
                    <%= post.subheading %>
                  </p>
                <% } %>

                <div class="flex flex-wrap items-center gap-2 mt-4 pt-3 border-t border-neutral-100 dark:border-neutral-800/40 text-xs">
                  <time class="text-neutral-400 dark:text-neutral-500" datetime="<%= post.publishedDate %>">
                    <%= formatTime(post.publishedDate) %>
                  </time>
                  <span class="text-neutral-300 dark:text-neutral-700">&bull;</span>
                  <span class="text-neutral-400 dark:text-neutral-500">
                    <%= getReadingTime(post.html) %>
                  </span>
                  <% if (post.tags && post.tags.length > 0) { %>
                    <span class="text-neutral-300 dark:text-neutral-700">&bull;</span>
                    <%- include('../../partials/tags', { tags: post.tags }) %>
                  <% } %>
                </div>
              </a>
            </article>
          <% }) %>
        </div>

      </div>
      <% }) %>
  </div>
</div>
