<div class="container mx-auto px-4 max-w-none pb-24 md:pb-16" style="flex: 1">
  <h1 class="text-center text-5xl font-light mt-8 mb-8 md:mt-16 md:mb-16 text-violet-950 dark:text-violet-300">Posts</h1>
  <div class="mt-12">
    <% yearGroups.forEach(([year, yearPosts]) => { %>
      <div class="mb-16">
        <h2 class="text-4xl font-light mb-8 text-violet-300 dark:text-violet-700"><%= year %></h2>
        <% yearPosts.forEach(post => { %>
          <div class="mt-10">
            <h3 class="text-2xl sm:text-3xl font-light mb-3">
              <a class="text-gray-900 dark:text-gray-100 hover:text-brand dark:hover:text-brand-light transition-colors" href="/posts/<%= post.slug %>"><%= post.title %></a>
            </h3>
            <% if (post.subheading) { %>
              <p class="mt-1 text-base leading-relaxed text-gray-600 dark:text-gray-400 mb-3 max-w-2xl"><%= post.subheading %></p>
            <% } %>
            <div class="flex flex-wrap items-center gap-2 mb-2">
              <p class="text-gray-500 dark:text-gray-400"><%= formatTime(post.publishedDate) %></p>
              <% if (post.tags && post.tags.length > 0) { %>
                <span class="text-gray-400 dark:text-gray-500">&bull;</span>
                <%- include('../../partials/tags', { tags: post.tags }) %>
              <% } %>
            </div>
          </div>
        <% }) %>
      </div>
    <% }) %>
  </div>
</div>
