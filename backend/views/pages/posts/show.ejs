<div class="container mx-auto mt-8 px-4 max-w-none pb-24 md:pb-16" style="flex: 1" data-controller="highlight">
  <div class="article mt-6">
    <h1 class="text-center text-4xl font-heading font-normal mb-3 text-violet-950 dark:text-brand-light"><%= post.title %></h1>
    <% if (post.subheading) { %>
      <p class="text-center text-xl text-gray-600 dark:text-gray-400 mb-3"><%= post.subheading %></p>
    <% } %>
    <div class="flex flex-wrap items-center justify-center gap-2 mb-12">
      <p class="text-gray-500 dark:text-gray-400"><%= formatTime(post.publishedDate) %></p>
      <% if (post.tags && post.tags.length > 0) { %>
        <span class="text-gray-400 dark:text-gray-500">&bull;</span>
        <%- include('../../partials/tags', { tags: post.tags }) %>
      <% } %>
    </div>
    <div class="prose sm:prose-lg dark:prose-invert" style="text-align: justify; overflow-wrap: break-word">
      <%- post.html %>
    </div>
  </div>
</div>
