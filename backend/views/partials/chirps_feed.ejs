<div class="<%= displayMode === 'timeline' ? 'overflow-hidden border-y border-neutral-200/70 bg-white divide-y divide-neutral-200/70 sm:rounded-lg sm:border dark:border-neutral-800/80 dark:bg-neutral-900/15 dark:divide-neutral-800/80' : 'flex flex-col gap-6' %>">
  <% const allChirps = chirpGroups.flatMap(group => group.chirps) %>
  <% allChirps.forEach((chirp) => { %>
    <article class="<%= displayMode === 'timeline' ? 'p-5 sm:p-6' : 'p-5 sm:p-6 rounded-2xl bg-white dark:bg-neutral-900/15 border border-neutral-200/70 dark:border-neutral-800/80 transition-all duration-200 shadow-sm hover:shadow' %>">
      <div class="chirp-content text-neutral-800 dark:text-neutral-200 leading-relaxed text-[15px]" style="word-wrap: break-word; line-height: 1.6">
        <%- chirp.html %>
      </div>
      <div class="mt-4 flex items-center gap-2 text-xs">
        <time class="text-neutral-400 dark:text-neutral-500" datetime="<%= chirp.publishedDate %>">
          <%= new Date(chirp.publishedDate).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %>
        </time>
        <% if (chirp.tags && chirp.tags.length > 0) { %>
          <span class="text-neutral-300 dark:text-neutral-700">&bull;</span>
          <%- include('tags', { tags: chirp.tags }) %>
        <% } %>
      </div>
    </article>
  <% }) %>
</div>
