<div class="flex flex-col gap-6">
  <% const allChirps = chirpGroups.flatMap(group => group.chirps) %>
  <% allChirps.forEach((chirp) => { %>
    <article class="p-5 sm:p-6 rounded-2xl bg-white dark:bg-neutral-900/15 border border-neutral-200/70 dark:border-neutral-800/80 hover:border-brand/30 dark:hover:border-brand-light/35 transition-all duration-200 shadow-sm hover:shadow">
      <div class="chirp-content text-neutral-800 dark:text-neutral-200 leading-relaxed text-[15px]" style="word-wrap: break-word; line-height: 1.6">
        <%- chirp.html %>
      </div>
      <div class="mt-4 pt-3 border-t border-neutral-100 dark:border-neutral-800/40 flex items-center gap-2 text-xs">
        <time class="text-neutral-400 dark:text-neutral-500" datetime="<%= chirp.publishedDate %>">
          <%= new Date(chirp.publishedDate).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %>
        </time>
        <% if (chirp.tags && chirp.tags.length > 0) { %>
          <span class="text-neutral-300 dark:text-neutral-700">&bull;</span>
          <%- include('tags', { tags: chirp.tags }) %>
        <% } %>
        <a href="/chirps/<%= chirp.slug %>" class="ml-auto text-neutral-400 dark:text-neutral-500 hover:text-brand dark:hover:text-brand-light transition-colors p-1" title="Permalink">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.2" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round">
            <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path>
            <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path>
          </svg>
        </a>
      </div>
    </article>
  <% }) %>
</div>
