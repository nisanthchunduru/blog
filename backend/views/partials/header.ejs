<%
  const currentPagePath = typeof currentPath !== 'undefined' ? currentPath : ''
  const navLinkClasses = 'inline-flex items-center rounded-full px-3.5 py-1.5 text-sm font-medium transition-all duration-200'
  const activeNavLinkClasses = `${navLinkClasses} bg-brand text-white shadow-sm shadow-violet-500/20 dark:bg-brand-light dark:text-brand-dark`
  const inactiveNavLinkClasses = `${navLinkClasses} text-neutral-700 hover:bg-violet-100/70 hover:text-brand dark:text-neutral-300 dark:hover:bg-violet-900/30 dark:hover:text-brand-light`
  const isPostsActive = currentPagePath.startsWith('/posts')
  const isChirpsActive = currentPagePath.startsWith('/chirps')
%>
<div class="pt-4 sm:pt-6 md:pt-8 pb-3 sm:pb-4 relative">
  <div class="container mx-auto px-4 max-w-5xl flex justify-between items-center">
    <a href="/" class="flex items-center gap-2.5 font-heading font-normal text-2xl sm:text-3xl text-gray-900 dark:text-gray-100 hover:text-brand dark:hover:text-brand-light transition-colors">
      <img src="<%= assetPath('images/logo.svg') %>" alt="Logo" class="w-12 h-12 sm:w-14 sm:h-14 flex-shrink-0" />
    </a>
    <nav class="flex items-center rounded-full border border-violet-200/70 bg-white/75 px-1.5 py-1 shadow-sm shadow-violet-950/5 backdrop-blur dark:border-violet-800/50 dark:bg-neutral-950/55 dark:shadow-black/20">
      <ul class="flex items-center gap-1">
        <li>
          <a class="<%= isPostsActive ? activeNavLinkClasses : inactiveNavLinkClasses %>" href="/posts" <%- isPostsActive ? 'aria-current="page"' : '' %>>Posts</a>
        </li>
        <li>
          <a class="<%= isChirpsActive ? activeNavLinkClasses : inactiveNavLinkClasses %>" href="/chirps" <%- isChirpsActive ? 'aria-current="page"' : '' %>>Chirps</a>
        </li>
        <li class="hidden md:list-item">
          <a class="<%= inactiveNavLinkClasses %>" href="https://www.linkedin.com/in/nisanthchunduru" target="_blank" rel="noopener noreferrer">LinkedIn</a>
        </li>
        <li class="hidden md:list-item">
          <a class="<%= inactiveNavLinkClasses %>" href="https://github.com/nisanthchunduru" target="_blank" rel="noopener noreferrer">GitHub</a>
        </li>
      </ul>
    </nav>
    <div class="flex items-center gap-1">
      <button
        class="p-2 text-gray-700 dark:text-gray-300 hover:text-brand dark:hover:text-brand-light transition-colors rounded-full bg-gray-100 dark:bg-gray-800"
        aria-label="Switch to dark mode"
        data-action="theme#toggle"
      >
        <span data-theme-target="icon">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5"><path fill-rule="evenodd" d="M9.528 1.718a.75.75 0 01.162.819A8.97 8.97 0 009 6a9 9 0 009 9 8.97 8.97 0 003.463-.69.75.75 0 01.981.98 10.503 10.503 0 01-9.694 6.46c-5.799 0-10.5-4.701-10.5-10.5 0-4.368 2.667-8.112 6.46-9.694a.75.75 0 01.818.162z" clip-rule="evenodd" /></svg>
        </span>
      </button>
    </div>
  </div>
</div>
